# ---- AI provider: mock (no key needed) | deepseek | claude ----
AI_PROVIDER=mock

# DeepSeek (development — cheap, OpenAI-compatible)
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# Claude (production)
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-6

# ---- Threat intel enrichment (optional, free tiers available) ----
ABUSEIPDB_API_KEY=
VIRUSTOTAL_API_KEY=

# ---- Pipeline ----
UPLOAD_DIR=/tmp/sentinelai_uploads
MAX_UPLOAD_MB=200
MAX_OBSERVATIONS_TO_AI=80

# ---- AI quality ----
# Run a second AI pass that critiques its own findings (better accuracy, ~2x cost).
AI_SELF_VERIFY=0
# Cache AI responses keyed on the summary content (identical input -> no re-call).
AI_CACHE=1

# ---- Persistence ----
# SQLite database; analyses survive a server restart.
DB_PATH=/tmp/sentinelai_uploads/sentinelai.db
